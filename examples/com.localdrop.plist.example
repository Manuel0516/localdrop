<?xml version="1.0" encoding="UTF-8"?>
<!--
  macOS startup for LocalDrop (optional).

  Install:
    cp examples/com.localdrop.plist.example com.localdrop.plist
    # edit the Python and project paths below, then:
    mkdir -p ~/Library/LaunchAgents
    cp com.localdrop.plist ~/Library/LaunchAgents/com.localdrop.plist
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.localdrop.plist
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.localdrop</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>/Users/YOURNAME/projects/localdrop/main.py</string>
        <string>daemon</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/YOURNAME/projects/localdrop</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>
</dict>
</plist>
